generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Device {
  id        String        @id
  createdAt DateTime      @default(now())
  jobs      Job[]
  sessions  WorkSession[]
}

model Job {
  id                   String        @id @default(uuid())
  deviceId             String
  device               Device        @relation(fields: [deviceId], references: [id])
  name                 String
  hourlyRate           Float?
  commissionPercentage Float?
  commissionRequired   Boolean       @default(false)
  payFrequency         String        @default("weekly")
  payDay               Int?
  taxEnabled           Boolean       @default(false)
  breakDuration        Int?
  breakRate            Float?
  penaltyRatesEnabled      Boolean       @default(false)
  penaltyBaseRate          Float?
  publicHolidayRate        Float         @default(2.5)
  saturdayRate             Float         @default(1.5)
  sundayRate               Float         @default(2.0)
  saturdayHourlyRate       Float?
  sundayHourlyRate         Float?
  publicHolidayHourlyRate  Float?
  payWeekStart             Int?
  isActive                 Boolean       @default(true)
  createdAt            DateTime      @default(now())
  sessions             WorkSession[]
  overtimeTiers        OvertimeTier[]
}

model OvertimeTier {
  id         String @id @default(uuid())
  jobId      String
  job        Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  afterHours Float
  rate       Float
  order      Int    @default(0)
}

model WorkSession {
  id              String    @id @default(uuid())
  deviceId        String
  device          Device    @relation(fields: [deviceId], references: [id])
  jobId           String
  job             Job       @relation(fields: [jobId], references: [id])
  clockIn         DateTime
  clockOut        DateTime?
  notes           String?
  isPublicHoliday Boolean   @default(false)
  dailyRevenue    Float?
  createdAt       DateTime  @default(now())
  breaks          Break[]
}

model Break {
  id        String      @id @default(uuid())
  sessionId String
  session   WorkSession @relation(fields: [sessionId], references: [id])
  startTime DateTime
  endTime   DateTime?
  isPaid    Boolean     @default(false)
  createdAt DateTime    @default(now())
}
